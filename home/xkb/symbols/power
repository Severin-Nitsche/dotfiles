partial xkb_symbols "caps" {
  key <CAPS> {
    symbols[Group1] = [ Escape, Caps_Lock, ISO_Next_Group ],
    actions[Group1] = [
      SetMods(modifiers=Control),
      LockMods(modifiers=Lock),
      LockGroup(group=+1)
    ]
  };
};

partial xkb_symbols "alt3" {
  key <LALT> {
    symbols[Group1] = [ Alt_L ],
    actions[Group1] = [
      SetMods(modifiers=Mod5)
    ]
  };
};
